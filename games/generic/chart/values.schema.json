{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Generic Values",
  "properties": {
    "game": {
      "type": "object",
      "properties": {
        "image": {
          "type": "string"
        },
        "env": {
          "type": "object"
        },
        "storage": {
          "type": "object"
        },
        "resources": {
          "type": "object"
        },
        "agent": {
          "type": "object"
        },
        "ports": {
          "type": "array"
        }
      }
    },
    "fleet": {
      "type": "object"
    },
    "gameServer": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "nameOverride": { "type": "string" },
        "env": { "type": "object" },
        "tier": { "type": "string" }
      }
    },
    "networking": {
      "type": "object"
    },
    "security": {
      "type": "object"
    },
    "monitoring": {
      "type": "object"
    }
  }
