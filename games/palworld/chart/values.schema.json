{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "gameProfile": {
      "type": "object",
      "properties": {
        "nameOverride": { "type": "string" }
      }
    },
    "game": {
      "type": "object",
      "properties": {
        "image": { "type": "string" },
        "imagePullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "ports": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "containerPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "protocol": { "type": "string", "enum": ["TCP", "UDP"] }
            },
            "required": ["name", "containerPort"]
          }
        },
        "env": { "type": "object" },
        "resources": { "type": "object" },
        "storage": {
          "type": "object",
          "properties": {
            "size": { "type": "string" },
            "storageClass": { "type": "string" },
            "mountPath": { "type": "string" }
          }
        },
        "agent": {
          "type": "object",
          "properties": {
            "image": { "type": "string" },
            "version": { "type": "string" },
            "resources": { "type": "object" }
          }
        },
        "actions": { "type": "array" },
        "capabilities": {
          "type": "object",
          "properties": {
            "files": { "type": "boolean" },
            "sftp": { "type": "boolean" },
            "backup": { "type": "boolean" },
            "restoreFromSnapshot": { "type": "boolean" }
          }
        }
      },
      "required": ["image", "ports", "resources", "storage", "agent"]
    },
    "fleet": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "replicas": { "type": "integer", "minimum": 0 },
        "updateStrategy": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["RollingUpdate", "OnDelete"] }
          }
        }
      }
    },
    "networking": {
      "type": "object",
      "properties": {
        "exposeMode": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "HostPort"] }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "networkPolicy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "rcon": {
          "type": "object",
          "properties": {
            "password": { "type": "string" },
            "existingSecret": { "type": "string" }
          }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "library": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
